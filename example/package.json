{
  "name": "hardhat-safeheron-example",
  "private": true,
  "version": "0.0.0",
  "description": "Example Hardhat project using @safeheron/hardhat-safeheron",
  "scripts": {
    "start": "node scripts/run.js",
    "deploy": "npx hardhat ignition deploy ignition/modules/ExampleToken.ts --network sepolia",
    "interact": "npx hardhat run scripts/interact.ts --network sepolia",
    "interact:legacy": "npx hardhat run scripts/interact-legacy.ts --network sepolia"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.2",
    "@safeheron/hardhat-safeheron": "file:.."
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "dotenv": "^16.4.5",
    "hardhat": "^2.22.2",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">16 <=18.18"
  }
}
