# Safeheron Open API base URL
SAFEHERON_BASE_URL=https://api.safeheron.com

# Safeheron API key (from Safeheron Web Console)
SAFEHERON_API_KEY=

# Absolute path to your RSA private key PEM file
SAFEHERON_RSA_PRIVATE_KEY_PATH=/absolute/path/to/your-private-key.pem

# Absolute path to Safeheron's RSA public key PEM file
SAFEHERON_RSA_PUBLIC_KEY_PATH=/absolute/path/to/safeheron-public-key.pem

# Web3 wallet account key (the "account<...>" portion before "_web3" in the
# Safeheron Web Console wallet detail URL)
SAFEHERON_WEB3_ACCOUNT_KEY=

# Web3 wallet EVM address (shown at the top of the Safeheron wallet detail page)
SAFEHERON_WEB3_EVM_ADDRESS=

# Sepolia RPC endpoint (e.g. Infura / Alchemy / your own node)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID
